Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "production-server"

  config.vm.network "private_network", ip: "192.168.56.30"

  config.vm.network "forwarded_port",
    guest: 3000,
    host: 3002,
    auto_correct: true

  config.vm.provider "virtualbox" do |vb|
    vb.name = "Final-Project-Production"
    vb.memory = 2048
    vb.cpus = 2
  end

  config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "[1/5] Updating packages..."
    apt-get update -y

    echo "[2/5] Installing prerequisites..."
    apt-get install -y ca-certificates curl gnupg lsb-release

    echo "[3/5] Installing Docker official repository..."
    install -m 0755 -d /etc/apt/keyrings

    if [ ! -f /etc/apt/keyrings/docker.gpg ]; then
      curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
      chmod a+r /etc/apt/keyrings/docker.gpg
    fi

    echo \
      "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
      $(lsb_release -cs) stable" \
      > /etc/apt/sources.list.d/docker.list

    apt-get update -y

    echo "[4/5] Installing Docker..."
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    echo "[5/5] Configuring Docker..."
    systemctl enable docker
    systemctl start docker

    usermod -aG docker vagrant

    mkdir -p /opt/devops-app
    chown -R vagrant:vagrant /opt/devops-app

    echo "Production server is ready."
  SHELL
end